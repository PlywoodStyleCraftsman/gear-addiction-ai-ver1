* { box-sizing: border-box; }
body { margin: 0; background: #fff; color: #111; font-family: Arial, 'Hiragino Kaku Gothic ProN', 'Yu Gothic', Meiryo, sans-serif; }
button, input { font: inherit; }
.container { min-height: 100vh; padding: 48px 18px; display: flex; justify-content: center; }
.wrap { width: 100%; max-width: 860px; }
.hero { border: 4px solid #111; padding: 34px 22px; text-align: center; }
.brand { font-size: 13px; letter-spacing: .22em; font-weight: 800; margin-bottom: 18px; }
h1 { font-size: clamp(42px, 9vw, 86px); line-height: .92; margin: 0; letter-spacing: -0.06em; font-weight: 950; }
.lead { margin: 22px auto 0; max-width: 560px; font-weight: 800; line-height: 1.9; }
.search { margin: 26px auto 0; display: flex; gap: 10px; max-width: 620px; }
input { flex: 1; border: 3px solid #111; padding: 16px; font-weight: 800; outline: none; }
button { border: 3px solid #111; background: #111; color: #fff; padding: 16px 20px; font-weight: 900; cursor: pointer; }
button.secondary { background: #fff; color: #111; margin: 6px; }
.examples { margin-top: 20px; display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; }
.card { border: 3px solid #111; padding: 24px; margin-top: 22px; }
.card h2 { font-size: 30px; margin: 0 0 12px; }
.grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 14px; }
.item { border-top: 2px solid #111; padding-top: 12px; font-weight: 800; }
.label { font-size: 12px; letter-spacing: .16em; color: #555; display: block; margin-bottom: 6px; }
.score { font-size: 28px; letter-spacing: .1em; font-weight: 950; }
ul { margin: 8px 0 0; padding-left: 20px; font-weight: 800; line-height: 1.8; }
.words { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 12px; }
.word { border: 2px solid #111; padding: 10px 12px; font-weight: 900; background: #fff; color: #111; }
.footer { text-align: center; margin-top: 30px; font-weight: 900; letter-spacing: .12em; font-size: 12px; }
.note { font-size: 13px; line-height: 1.8; font-weight: 700; color: #333; }
.cta { border: 4px solid #111; padding: 24px; text-align: center; margin-top: 22px; }
.cta-title { font-size: 28px; font-weight: 950; margin-bottom: 10px; }
@media (max-width: 640px) { .search { flex-direction: column; } .grid { grid-template-columns: 1fr; } .hero { padding: 28px 16px; } }
